{
  "extends": ["../../tsconfig.common.json"],
  "compilerOptions": {
    "rootDir": "lib",
    "declarationDir": "lib_types",
    "emitDeclarationOnly": true,
    "composite": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["react", "react-dom"]
  },
  "include": [
    "lib/**/*.{ts,tsx}",
    "../../types/esbuild_css.d.ts",
    "../../types/react_css_vars.d.ts"
  ],
  "exclude": ["node_modules"]
}
