{
  "name": "@sidelines/github",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./lib_types/index.d.ts",
      "node": "./lib_js/index.js",
      "import": "./lib/index.ts"
    },
    "./*": {
      "types": "./lib_types/*.api.ts",
      "node": "./lib_js/*.api.js",
      "import": "./lib/*.api.ts"
    },
    "./GRAPHS": {
      "types": "./lib_types/graphs.d.ts"
    }
  },
  "imports": {
    "#rateLimit": {
      "node": "./lib/rateLimit.stub.ts",
      "default": "./lib/rateLimit.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "build:clean": "rm -rf lib_js lib_types tsconfig.tsbuildinfo",
    "graphql": "node graphql.ts && pnpm fmt:graphql",
    "fmt:graphql": "pnpm exec prettier --config ../../.prettierrc.ts --write \"**/gql.ts\" --log-level warn"
  },
  "dependencies": {
    "@sidelines/model": "workspace:*",
    "semver": "^7.8.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/semver": "^7.7.1",
    "graphql": "catalog:"
  }
}
