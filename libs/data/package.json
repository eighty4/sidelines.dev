{
  "name": "@sidelines/data",
  "private": true,
  "type": "module",
  "exports": {
    "./cookie": {
      "types": "./lib_types/cookie.d.ts",
      "node": "./lib_js/cookie.js",
      "default": "./lib/cookie.ts"
    },
    "./indexeddb/tx/*": {
      "types": "./lib_types/transactions/*.d.ts",
      "node": "./lib_js/transactions/*.js",
      "default": "./lib/transactions/*.ts"
    },
    "./indexeddb/dev": {
      "types": "./lib_types/database.d.ts",
      "node": "./lib_js/database.js",
      "default": "./lib/database.ts"
    },
    "./storage": {
      "types": "./lib_types/storage.d.ts",
      "node": "./lib_js/storage.js",
      "default": "./lib/storage.ts"
    }
  },
  "dependencies": {
    "@sidelines/github": "workspace:*",
    "@sidelines/model": "workspace:*",
    "@sidelines/packages": "workspace:*"
  }
}
