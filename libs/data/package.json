{
  "name": "@sidelines/data",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./cache/*": {
      "types": "./lib_types/caches/*.d.ts",
      "node": "./lib_js/caches/*.js",
      "default": "./lib/caches/*.ts"
    },
    "./cookie": {
      "types": "./lib_types/cookie.d.ts",
      "node": "./lib_js/cookie.js",
      "default": "./lib/cookie.ts"
    },
    "./indexeddb/tx/*": {
      "types": "./lib_types/transactions/*.d.ts",
      "node": "./lib_js/transactions/*.js",
      "default": "./lib/transactions/*.ts"
    },
    "./opfs": {
      "types": "./lib_types/opfs.d.ts",
      "node": "./lib_js/opfs.js",
      "default": "./lib/opfs.ts"
    },
    "./storage": {
      "types": "./lib_types/storage.d.ts",
      "node": "./lib_js/storage.js",
      "default": "./lib/storage.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "build:clean": "rm -rf lib_js lib_types tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@sidelines/github": "workspace:*",
    "@sidelines/model": "workspace:*",
    "@sidelines/packages": "workspace:*"
  }
}
