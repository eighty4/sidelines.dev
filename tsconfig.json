{
  "extends": ["./tsconfig.common.json"],
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.AsyncIterable", "DOM.Iterable", "WebWorker"],
    "target": "ES2022",
    "paths": {
      "$testing/*": ["./testing/*"]
    },
    "rewriteRelativeImportExtensions": false,
    "noUncheckedIndexedAccess": false
  },
  "include": [
    "dev/**/*.ts",
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "testing/**/*.ts",
    "pages/workers/**/*.ts",
    "global.d.ts"
  ],
  "exclude": ["node_modules"],
  "references": [
    { "path": "./libs/data" },
    { "path": "./libs/github" },
    { "path": "./libs/model" },
    { "path": "./libs/packages" },
    { "path": "./libs/pageload" },
    { "path": "./server" }
  ]
}
