{
  "extends": ["./tsconfig.common.json"],
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.AsyncIterable", "DOM.Iterable", "WebWorker"],
    "target": "ES2022",
    "rewriteRelativeImportExtensions": false,
    "noUncheckedIndexedAccess": false,
    "paths": {
      "Sidelines.dev/workers/*": ["./workers/*.ts"]
    },
    "types": ["@types/node"]
  },
  "include": [
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "tests/**/*.ts",
    "workers/**/*.ts",
    "global.d.ts",
    "*.ts"
  ],
  "exclude": ["node_modules"],
  "references": [
    { "path": "./libs/data" },
    { "path": "./libs/github" },
    { "path": "./libs/model" },
    { "path": "./libs/packages" },
    { "path": "./libs/pageload" },
    { "path": "./server" }
  ]
}
