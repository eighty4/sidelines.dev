{
  "extends": ["./tsconfig.common.json"],
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "WebWorker"],
    "target": "ES2022",
    "rewriteRelativeImportExtensions": false,
    "noUncheckedIndexedAccess": false,
    "paths": {
      "Sidelines.dev/workers/*": ["./workers/*.ts"]
    },
    "types": ["node", "react", "react-dom"]
  },
  "include": [
    "pages/**/*.{ts,tsx}",
    "tests/**/*.ts",
    "workers/**/*.ts",
    "types/*.d.ts",
    ".prettier.ts",
    "local.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules"],
  "references": [
    { "path": "./libs/data" },
    { "path": "./libs/github" },
    { "path": "./libs/model" },
    { "path": "./libs/packages" },
    { "path": "./libs/pageload" },
    { "path": "./server" }
  ]
}
