{
  "extends": ["./tsconfig.common.json"],
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "WebWorker"],
    "target": "ES2022",
    "rewriteRelativeImportExtensions": false,
    "types": ["node", "react", "react-dom"]
  },
  "include": [
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "tests/**/*.ts",
    "workers/**/*.ts",
    "types/*.d.ts",
    ".prettier.ts",
    "local.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules"],
  "references": [
    { "path": "./libs/data" },
    { "path": "./libs/github/tsconfig.lib.json" },
    { "path": "./libs/model/tsconfig.lib.json" },
    { "path": "./libs/packages/tsconfig.lib.json" },
    { "path": "./libs/pageload" },
    { "path": "./server" }
  ]
}
