{
  "name": "@sidelines/webapp",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "workspaces": [
    "libs/*"
  ],
  "scripts": {
    "build": "dank build",
    "build:libs": "pnpm exec tsc --build",
    "clean": "rm -rf build && tsc --build --clean",
    "dev": "dank serve",
    "fmt": "prettier --write .",
    "fmtcheck": "prettier --check .",
    "graphql": "pnpm --filter github graphql",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "node --test \"**/*.spec.ts\"",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@eighty4/dank": "0.0.5-4",
    "@eighty4/model-t": "0.0.5-4",
    "@sidelines/data": "workspace:*",
    "@sidelines/github": "workspace:*",
    "@sidelines/model": "workspace:*",
    "@sidelines/packages": "workspace:*",
    "@sidelines/pageload": "workspace:*",
    "@sidelines/server": "workspace:*",
    "@sidelines/ui": "workspace:*",
    "monaco-editor": "^0.54.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "esbuild": "0.25.11",
    "graphql": "^16.11.0",
    "parse5": "^8.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.9.3"
  }
}
