{
  "name": "@sidelines/webapp",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.15.0",
  "workspaces": [
    "libs/*"
  ],
  "scripts": {
    "build": "pnpm typecheck:app && dank build",
    "clean": "pnpm -r build:clean && rm -rf build",
    "dev": "dank serve",
    "fmt": "prettier --write . --log-level warn",
    "fmtcheck": "prettier --check .",
    "graphql": "pnpm --filter github graphql",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "node --test \"**/*.spec.ts\"",
    "test:e2e": "playwright test",
    "typecheck": "tsc",
    "typecheck:app": "tsc -p tsconfig.app.json"
  },
  "dependencies": {
    "@eighty4/model-t": "0.0.5-4",
    "@sidelines/data": "workspace:*",
    "@sidelines/github": "workspace:*",
    "@sidelines/jobs": "workspace:*",
    "@sidelines/model": "workspace:*",
    "@sidelines/packages": "workspace:*",
    "@sidelines/pageload": "workspace:*",
    "@sidelines/server": "workspace:*",
    "@sidelines/ui": "workspace:*",
    "monaco-editor": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@eighty4/dank": "0.0.5-13",
    "@playwright/test": "^1.61.1",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "esbuild": "0.28.1",
    "graphql": "catalog:",
    "parse5": "^8.0.1",
    "prettier": "^3.9.5",
    "typescript": "catalog:"
  }
}
